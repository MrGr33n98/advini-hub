# Dockerfile.ec2.backend\nFROM ruby:3.0.0-alpine\n\n# Install system dependencies\nRUN apk update && apk upgrade && apk add --no-cache \\\n    build-base \\\n    postgresql-dev \\\n    nodejs \\\n    yarn \\\n    imagemagick \\\n    git \\\n    curl \\\n    bash\n\nWORKDIR /app\n\n# Copy Gemfile and install dependencies\nCOPY backend_rails/Gemfile backend_rails/Gemfile.lock ./\n\nRUN gem install bundler && \\\n    bundle config set --local without 'development test' && \\\n    bundle install --jobs 4 --retry 3\n\n# Copy application code\nCOPY backend_rails .\n\n# Precompile assets\nRUN RAILS_ENV=production SECRET_KEY_BASE=dummy bundle exec rake assets:precompile\n\n# Create a non-root user\nRUN addgroup -g 1001 -S appgroup && \\\n    adduser -S appuser -u 1001 -G appgroup\n\n# Change ownership of the application directory\nRUN chown -R appuser:appgroup /app\nUSER appuser\n\nEXPOSE 3001\n\nCMD [\"sh\", \"-c\", \"bundle exec rake db:create db:migrate && bundle exec rails server -b 0.0.0.0 -p 3001\"]\n