# .gitignore
# See https://help.github.com/articles/keeping-files-out-of-git/ for more about ignoring files.

# Dependencies
node_modules/
vendor/bundle
.bundle
vendor/cache
.yarn-integrity
.yarn/cache
.yarn/build-state.gz

# Testing
.rspec
spec/reports/
*.seed
features/reports/

# Caching
.ruby-gemset
.ruby-version
tmp/
.rails
public/system
storage

# Coverage
coverage/
*.lcov

# Logs
log/*
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime
pids
*.pid
*.seed

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# IDE
.vscode
.idea
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Database
db/*.sqlite3
db/*.sqlite3-journal
*.db

# Secrets
config/master.key
config/credentials.yml.enc

# Build outputs
dist/
build/
.next/
.nuxt/
out/

# CI/CD
.github/
.circleci/
.travis.yml
jenkins/
.drone.yml

# Documentation
docs/_build/

# Temporary files
*.tmp
*.bak
*.orig
*.rej

# IDE specific
.vs/
*.sublime-project
*.sublime-workspace